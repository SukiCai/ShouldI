{
  "name": "@shouldi/mobile",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "description": "Expo Router client — Explore, Decide wizard, onboarding for ShouldI.",
  "scripts": {
    "prestart": "npm run generate:icons && npm run build --workspace=@shouldi/contracts --if-present",
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web --port ${EXPO_WEB_PORT:-8082}",
    "web:clear": "expo start --web --port ${EXPO_WEB_PORT:-8082} --clear",
    "generate:icons": "node scripts/render-app-icons.mjs"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-navigation/native": "^7.1.8",
    "@shouldi/contracts": "*",
    "@tanstack/react-query": "^5.76.2",
    "expo": "~54.0.33",
    "expo-blur": "~15.0.8",
    "expo-constants": "~18.0.13",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-linear-gradient": "^55.0.13",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.23",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.10",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@types/react": "18.3.28",
    "@types/react-dom": "18.3.7",
    "react-test-renderer": "19.1.0",
    "sharp": "^0.34.2",
    "typescript": "~5.9.2"
  },
  "private": true
}
