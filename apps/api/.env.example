# Copy to apps/api/.env for local overrides (loaded if you use dotenv in dev — or export manually).

# Hermes gateway api_server (OpenAI-compatible)
HERMES_API_URL=http://127.0.0.1:8642
HERMES_API_KEY=change-me-local-dev

# Optional overrides
# HERMES_ROOT=/absolute/path/to/hermes-agent-private
# HERMES_REQUEST_TIMEOUT_MS=180000
# HERMES_API_MODEL=hermes-agent
# PORT=8787
