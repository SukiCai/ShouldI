# Copy to `.env` in the ShouldI repo root for `docker compose up`.
# Do not commit real keys.

# --- Hermes agent (LLM provider — at least one required) ---
# Match the provider configured in ~/.hermes/config.yaml after setup.
OPENROUTER_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=

# Shared secret: Hermes api_server ↔ ShouldI API
HERMES_API_KEY=change-me-local-dev
API_SERVER_KEY=change-me-local-dev

# Optional: reuse an existing Hermes home from host setup (`hermes setup` on Mac)
# SHOULDI_HERMES_DATA=/Users/you/.hermes
# Match host user so the bind mount is writable inside the container:
# HERMES_UID=501
# HERMES_GID=20

# Published host ports (change if already in use)
# SHOULDI_API_HOST_PORT=8787
# SHOULDI_WEB_HOST_PORT=18080
# SHOULDI_HERMES_HOST_PORT=8642
